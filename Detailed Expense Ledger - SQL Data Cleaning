# These SQL queries were used to clean the Detailed Expense Ledger file 

-- USED TO DISPLAY THE TABLE AS I MADE EDITS TO IT 
SELECT * FROM EXPENSES
ORDER BY DESCRIPTION;

-- TRIM EXCESS SPACES FROM THE DATA 
UPDATE EXPENSES
SET EXPENSEID = TRIM(EXPENSEID), DATE = TRIM(DATE), EXPENSECATEGORY = TRIM(EXPENSECATEGORY),
DESCRIPTION = TRIM(DESCRIPTION), AMOUNT = TRIM(AMOUNT), DEPARTMENT = TRIM(DEPARTMENT);

-- DELETE ROWS WITH BLANK AMOUNTS
DELETE FROM EXPENSES
WHERE AMOUNT = ''
OR AMOUNT = '#N/A';

-- REPLACE #N/A WITH BLANK DATA
UPDATE EXPENSES
SET EXPENSEID = ''
WHERE EXPENSEID = '#N/A';

UPDATE EXPENSES
SET DATE = ''
WHERE DATE = '#N/A';

UPDATE EXPENSES
SET EXPENSECATEGORY = ''
WHERE EXPENSECATEGORY = '#N/A';

UPDATE EXPENSES
SET DESCRIPTION = ''
WHERE DESCRIPTION = '#N/A';

UPDATE EXPENSES
SET DEPARTMENT = ''
WHERE DEPARTMENT = '#N/A';

-- ADD AN ID COLUMN TO MATCH THE EXPENSE ID AND THEN UPDATE THE EXPENSE ID COLUMN TO MATCH IT
ALTER TABLE EXPENSES
ADD ID INT PRIMARY KEY;

UPDATE EXPENSES
SET ID = (ID+21999);

UPDATE EXPENSES
SET EXPENSEID = CONCAT('EXP-',ID);

-- CONTROL WHICH ROWS ARE RETURNED AFTER GROUPING BY DESCRIPTION AND AMOUNT
-- THE FIRST CTE ASSIGNED A VALUE BASED ON HOW MANY MISSING PIECES OF INFORMATION ARE IN THE ROW
-- THE SECOND ASSIGNS A ROW NUMBER AFTER GROUPING BY DESCRIPTION AND AMOUNT, ORDERED BY THE NUMBER OF BLANKS
-- THE LAST QUERY REMOVES DUPLICATES, PRESERVING THE ONE WITH THE LEAST AMOUNT OF MISSING INFO
WITH BLANKS AS (
SELECT *, CASE
WHEN DATE='' AND EXPENSECATEGORY='' AND DEPARTMENT='' THEN 3
WHEN DATE='' AND EXPENSECATEGORY='' THEN 2
WHEN DATE='' AND DEPARTMENT='' THEN 2
WHEN EXPENSECATEGORY='' AND DEPARTMENT='' THEN 2
WHEN DATE='' OR EXPENSECATEGORY='' OR DEPARTMENT='' THEN 1
ELSE 0
END AS BLANKS
FROM EXPENSES),

DUPES AS (
SELECT *,
ROW_NUMBER() OVER (PARTITION BY DESCRIPTION, AMOUNT ORDER BY BLANKS ASC) AS ROWNUM
FROM BLANKS
ORDER BY DESCRIPTION)

SELECT EXPENSEID, DATE, EXPENSECATEGORY, DESCRIPTION, AMOUNT, DEPARTMENT
FROM DUPES 
WHERE ROWNUM = 1
ORDER BY EXPENSEID ASC;
